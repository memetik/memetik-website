{
  "buildCommand": "node scripts/build-articles.cjs && node scripts/build-sitemap.cjs && node scripts/build-llms-txt.cjs && npm run build:client && node scripts/prerender.cjs",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
