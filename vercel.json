{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/contact",
      "destination": "/audit",
      "permanent": true
    },
    {
      "source": "/demo",
      "destination": "/audit",
      "permanent": true
    },
    {
      "source": "/get-started",
      "destination": "/audit",
      "permanent": true
    },
    {
      "source": "/answer-engine-optimization-services",
      "destination": "/aeo-agency",
      "permanent": true
    },
    {
      "source": "/ai-search-optimization-agency",
      "destination": "/aeo-agency",
      "permanent": true
    },
    {
      "source": "/resources/questions-before-hiring-aeo-agency",
      "destination": "/resources/questions-to-ask-before-hiring-aeo-agency",
      "permanent": true
    },
    {
      "source": "/resources/chatgpt-search-statistics-b2b-2025",
      "destination": "/resources/chatgpt-search-statistics-b2b-marketers",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
